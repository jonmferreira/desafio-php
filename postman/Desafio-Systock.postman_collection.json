					"name": "Login - sucesso",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const body = pm.response.json();",
									"pm.test('Token presente na resposta', () => pm.expect(body.token).to.be.a('string'));",
									"if (body.token) { pm.environment.set('token', body.token); }"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@systock.com.br\",\n  \"password\": \"password\"\n}"
						},
