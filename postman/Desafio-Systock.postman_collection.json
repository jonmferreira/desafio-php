{
	"info": {
		"name": "Desafio Systock",
		"description": "Testes funcionais e de segurança da API Systock — Users, Products, Lotes, Lote Items, Avarias, Saídas e Reports. Ver postman/README.md para instruções de uso.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login - sucesso",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const body = pm.response.json();",
									"pm.test('Token presente na resposta', () => pm.expect(body.token).to.be.a('string'));",
									"if (body.token) { pm.environment.set('token', body.token); }"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@systock.com.br\",\n  \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
				},
				{
					"name": "Login - credenciais invalidas (Broken Authentication - API2)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 401/422', () => pm.expect([401, 422]).to.include(pm.response.code));",
									"pm.test('Mensagem nao revela se o e-mail existe (sem enumeracao de usuarios)', () => {",
									"  const body = pm.response.json();",
									"  const text = JSON.stringify(body).toLowerCase();",
									"  pm.expect(text).to.not.include('not found');",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"naoexiste@systock.com.br\",\n  \"password\": \"senhaerrada\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
				},
				{
					"name": "Acessar rota protegida sem token (Broken Authentication - API2)",
